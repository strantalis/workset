{
	"name": "frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build:dev": "vite build --minify false --mode development",
		"build": "vite build",
		"postbuild": "node ./scripts/ensure-dist-gitkeep.mjs",
		"perf:audit:build": "npm run build && node ./scripts/perf-audit-build.mjs",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "PLAYWRIGHT_BROWSERS_PATH=.playwright playwright test",
		"test:e2e:headed": "PLAYWRIGHT_BROWSERS_PATH=.playwright playwright test --headed",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.2.7",
		"@tsconfig/svelte": "^5.0.8",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.54.0",
		"@vitest/coverage-v8": "^4.0.18",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"jsdom": "^29.0.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"svelte": "^5.54.1",
		"svelte-check": "^4.4.4",
		"svelte-language-server": "^0.17.29",
		"svelte-preprocess": "^6.0.3",
		"tailwindcss": "^4.2.0",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@codemirror/autocomplete": "^6.20.1",
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-css": "^6.3.1",
		"@codemirror/lang-go": "^6.0.1",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/lang-javascript": "^6.2.5",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/lang-python": "^6.2.1",
		"@codemirror/lang-yaml": "^6.1.2",
		"@codemirror/language": "^6.12.2",
		"@codemirror/legacy-modes": "^6.5.2",
		"@codemirror/merge": "^6.12.1",
		"@codemirror/search": "^6.6.0",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.40.0",
		"@iconify-json/file-icons": "^1.2.2",
		"@iconify/svelte": "^5.2.1",
		"@lucide/svelte": "^0.575.0",
		"@pierre/diffs": "^1.0.11",
		"@strantalis/workset-ghostty-web": "^0.3.1-workset.15",
		"@wailsio/runtime": "^3.0.0-alpha.79",
		"codemirror-lang-hcl": "^0.1.0",
		"dompurify": "^3.3.1",
		"fzf": "^0.5.2",
		"marked": "^17.0.5",
		"mermaid": "^11.12.3",
		"shiki": "^4.0.2"
	}
}
